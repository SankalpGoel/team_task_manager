# Virtualenv / local Python (never ship into the image)
.venv/
venv/
env/

# Python caches & build
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/

# Secrets & local env (Render injects env vars at runtime)
.env
.env.*
!.env.example

# Tests aren't needed at runtime
tests/

# VCS / tooling / docs
.git/
.gitignore
.dockerignore
Dockerfile
*.md

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/
